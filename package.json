{
  "name": "flashcard",
  "version": "1.0.0",
  "productName": "FlashCard",
  "description": "Learn with spaced repetition flashcards",
  "author": "Allister Kohn <allister.kohn@gmail.com>",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build:renderer": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outdir=dist-electron --out-extension:.js=.cjs",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "dev": "npm run build:electron && node scripts/dev.mjs",
    "dist": "npm run build && electron-builder --mac",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-router": "^1.131.36",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emojibase-data": "^17.0.0",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.3",
    "vite": "^8.0.2"
  },
  "build": {
    "appId": "com.allisterkohn.flashcard",
    "productName": "FlashCard",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  },
  "allowScripts": {
    "electron@38.8.6": true,
    "esbuild@0.27.7": true,
    "electron-winstaller@5.4.0": true
  }
}
